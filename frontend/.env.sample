# Vite only exposes env vars prefixed with VITE_ to import.meta.env — the
# REACT_APP_ prefix is a Create React App convention and is invisible here.
# bin/generate-env.sh already writes both prefixes to .env.local for you;
# this sample is only for running the frontend without the full local stack.
VITE_API_URL=http://localhost:3001
VITE_API_ENDPOINTS='{}'
